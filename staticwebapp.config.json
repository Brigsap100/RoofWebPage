{
  "platform": {
    "apiRuntime": "node:20"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/data-api/*", "/assets/*", "/css/*", "/js/*", "/crm/*", "/hr/*", "*.{png,jpg,jpeg,webp,svg,ico}"]
  },
  "mimeTypes": {
    ".webp": "image/webp",
    ".svg": "image/svg+xml"
  },
  "globalHeaders": {
    "cache-control": "public, max-age=3600"
  }
}
